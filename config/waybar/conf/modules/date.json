{
    "clock": {
        "interval":1,
        "timezone":"Europe/Madrid",
        "locale": "es_ES.UTF-8",
        "format": "{:%d %h | %H:%M}",
        "format-alt": "{:%A, %B %d, %Y (%R)}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode"          : "year",
            "mode-mon-col"  : 3,
            "weeks-pos"     : "left",
            "on-scroll"     : 1,
            "on-click-right": "mode",
            "format": {
                "months":     "<span color='#3474eb'><b>{}</b></span>",
                "days":       "<span color='#ebeced'><b>{}</b></span>",
                "weeks":      "<span color='#5fcc49'><i>{}</i></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#d121de'><b><u>{}</u></b></span>"
            }
        },
        "actions":  {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    }
}
