#!/bin/bash

# Hyprland Session Wrapper for Ly (and other non-systemd display managers)

# Set XDG directories
export XDG_SESSION_TYPE=wayland
export XDG_SESSION_DESKTOP=Hyprland
export XDG_CURRENT_DESKTOP=Hyprland

# Qt variables
export QT_QPA_PLATFORM="wayland;xcb"
export QT_QPA_PLATFORMTHEME=qt5ct
export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
export QT_AUTO_SCREEN_SCALE_FACTOR=1

# GTK variables
export GDK_BACKEND=wayland,x11
export GTK_THEME=Adwaita-dark  # Ajusta según tu tema
export GTK_USE_PORTAL=1

# Clutter
export CLUTTER_BACKEND=wayland

# Mozilla/Firefox
export MOZ_ENABLE_WAYLAND=1

# SDL
export SDL_VIDEODRIVER=wayland

# Java applications
export _JAVA_AWT_WM_NONREPARENTING=1

# Electron apps (VS Code, Discord, etc.)
export ELECTRON_OZONE_PLATFORM_HINT=auto

# NVIDIA specific (descomenta si tienes NVIDIA)
export LIBVA_DRIVER_NAME=nvidia
export GBM_BACKEND=nvidia-drm
export __GLX_VENDOR_LIBRARY_NAME=nvidia
export __NV_PRIME_RENDER_OFFLOAD=1
export __VK_LAYER_NV_optimus=NVIDIA_only

# Fix for some Java apps
# export AWT_TOOLKIT=MToolkit

# Dbus
if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
    eval $(dbus-launch --sh-syntax --exit-with-session)
fi

# Cosas
export XCURSOR_THEME=Nord
export XCURSOR_SIZE=24

# Start Hyprland
exec Hyprland
